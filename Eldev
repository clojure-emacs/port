; -*- mode: emacs-lisp; lexical-binding: t -*-

(eldev-require-version "1.8.2")

(setf eldev-project-source-dirs '("lisp/"))
(setf eldev-project-main-file "port.el")

(eldev-use-package-archive 'gnu)
(eldev-use-package-archive 'melpa-unstable)

(eldev-use-plugin 'autoloads)

(eldev-add-loading-roots 'test "test/")

(setq byte-compile-docstring-max-column 100)
(setq checkdoc-permit-comma-termination-flag t)

;; package-lint runs file-by-file and otherwise treats every module as a
;; standalone package, which generates a flood of false positives on a
;; multi-file package whose Package-Requires lives in the main file.
;; Pointing it at the main file makes those go away.
(with-eval-after-load 'package-lint
  (setq package-lint-main-file "lisp/port.el"))
